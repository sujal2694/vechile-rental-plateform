# ⚠️ NEVER COMMIT .env FILE WITH REAL CREDENTIALS ⚠️
# Use this file as a template and create .env with real values locally

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vehicle-rental-shop

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_characters

# Server Configuration
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000

# Frontend URLs (CORS)
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Stripe Configuration (get from https://stripe.com/dashboard)
# Use test keys in development, live keys only in production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration (optional - for contact form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Admin User (for seeding database)
ADMIN_EMAIL=admin@vehiclerental.com
ADMIN_PASSWORD=AdminPassword123

# Session & Security
SESSION_SECRET=your_session_secret_key_here
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=info